{
  "name": "diffcore",
  "version": "1.2.0",
  "description": "Fast WebAssembly JSON diff engine. Returns real JSON Pointer paths and decoded values. Includes applyPatch, revertPatch, RFC 6902 JSON Patch output, a React hook, and a CLI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "diffcore": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./state": {
      "import": "./dist/state.js",
      "types": "./dist/state.d.ts"
    },
    "./worker": {
      "import": "./dist/worker.js",
      "types": "./dist/worker.d.ts"
    },
    "./wasm": "./dist/diffcore.wasm",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "llms.txt",
    "llms-full.txt",
    "LICENSE"
  ],
  "scripts": {
    "build:wasm": "cargo build --release --target wasm32-unknown-unknown && mkdir -p pkg && cp target/wasm32-unknown-unknown/release/diffcore.wasm pkg/",
    "build:js": "tsc",
    "build:bundle": "node scripts/embed-wasm.mjs",
    "build": "npm run build:wasm && npm run build:js && npm run build:bundle",
    "prepublishOnly": "npm run build",
    "test": "npm run test:legacy && npm run test:ux && npm run test:unit",
    "test:legacy": "node test/edge-cases.mjs && node test/stress.mjs && node test/smoke.mjs && node test/v1.2-features.mjs && node test/v1.4-state.mjs",
    "test:ux": "node --test test/ux/",
    "test:unit": "node --test test/unit/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DibbayajyotiRoy/rust-wasm-Library.git"
  },
  "homepage": "https://github.com/DibbayajyotiRoy/rust-wasm-Library#readme",
  "bugs": {
    "url": "https://github.com/DibbayajyotiRoy/rust-wasm-Library/issues"
  },
  "keywords": [
    "json",
    "json-diff",
    "diff",
    "delta",
    "json-patch",
    "rfc6902",
    "json-pointer",
    "patch",
    "apply-patch",
    "merge",
    "three-way-merge",
    "merge-conflict",
    "undo-redo",
    "history",
    "optimistic-update",
    "state-sync",
    "state-management",
    "change-tracking",
    "audit-log",
    "compare-json",
    "object-diff",
    "deep-diff",
    "crdt-alternative",
    "wasm",
    "webassembly",
    "rust",
    "simd",
    "streaming",
    "fast",
    "react",
    "typescript",
    "nodejs",
    "cli"
  ],
  "author": "DibbayajyotiRoy",
  "license": "MIT",
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "react": "^18.3.1",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
